# ============================================================================
# SecureStack Portfolio — .gitignore
# ============================================================================
# Comprehensive Git ignore rules for Next.js React portfolio
# with TypeScript, Tailwind CSS, and modern development tools
# Last Updated: March 29, 2026
# ============================================================================


# ============================================================================
# SECTION 1: NODE.JS & NPM DEPENDENCIES
# ============================================================================
node_modules/
npm-debug.log*
npm-error.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*
pnpm-error.log*
.pnpm-store/
package-lock.json
yarn.lock
pnpm-lock.yaml


# ============================================================================
# SECTION 2: BUILD & COMPILATION OUTPUT
# ============================================================================
# Next.js
.next/
out/
.vercel/
.prerender-manifest.json

# React & Webpack
dist/
build/
.parcel-cache/
.turbo/

# TypeScript
*.tsbuildinfo
compiled/
.tsc-out/
.tsbuildinfo

# Testing
.jest-cache/
coverage/
.vite/

# General build artifacts
lib/
esm/
.cache/


# ============================================================================
# SECTION 3: ENVIRONMENT & CONFIGURATION (SECURITY CRITICAL)
# ============================================================================
# Environment files — NEVER commit these
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.*.local
.env.*.production

# Configuration files with secrets
config/secrets.js
config/local.js
.config.local.json

# ============================================================================
# SECTION 3.5: TEST REPORTS & COVERAGE
# ============================================================================
# Jest coverage
coverage/
.nyc_output/

# Playwright test reports
playwright-report/
test-results/

# Lighthouse CI reports
.lighthouseci/

# ============================================================================
# SECTION 4: IDE & EDITOR FILES
# ============================================================================
# Visual Studio Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.vscode-test/
.vscode-test-e2e/
*.vsix
.idea/

# JetBrains IDEs (WebStorm, IntelliJ IDEA, etc.)
.idea/
*.iml
*.iws
*.ipr
*.sublime-project
*.sublime-workspace
.jb/

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#.*\#
.\#*

# Nano
.nano-history
.nano_history

# General editor backups
*.bak
*.backup
*~


# ============================================================================
# SECTION 5: OPERATING SYSTEM FILES
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Icon?
.TemporaryItems

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.shortcut
*.stackdump

# Linux
.directory
.Trash-*
*.swp
*.swo


# ============================================================================
