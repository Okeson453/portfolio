# ============================================================================
coverage/
.nyc_output/
.coverage
htmlcov/
.pytest_cache/
__pycache__/
*.pytest_cache/
test-results/
test-report.html
test-report.json
.mocharc.json.tmp
.jest-cache/
.vitest/


