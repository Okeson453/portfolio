# ============================================================================
# Cryptographic keys
*.pem
*.key
*.cert
*.crt
*.cer
*.p8
*.p12
*.pfx
private_key.*
public_key.*
id_rsa*
id_dsa*
id_ed25519*

# Credential files
.ssh/
.netrc
.git-credentials
credentials.json
service-account-key.json
apikeys.json
secrets/
private/
.secrets/

# API keys & tokens (in comments or files)
.api_key
.api_keys
.tokens


