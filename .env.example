# ─────────────────────────────────────────────────────────────────────────────
# SECURESTACK PORTFOLIO — ENVIRONMENT CONFIGURATION
# Copy to .env.local: `cp .env.example .env.local`
# Run interactive setup: `npm run setup:env`
# ─────────────────────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════════════════════
# TIER 1 — REQUIRED (App will not start without these)
# ══════════════════════════════════════════════════════════════════════════════

# [REQUIRED] Public application URL
# - Used for: OpenGraph images, email redirects, sitemap generation, canonical URLs
# - Value: The base URL where the app is deployed
# - Local: http://localhost:3000
# - Production: https://okeson.dev
# - Type: String (URL)
# - Security: NEXT_PUBLIC_* = safe to expose
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [REQUIRED] PostgreSQL connection string
# - Used for: Database connectivity for all data operations
# - Format: postgresql://username:password@host:port/database?sslmode=disable|require
# - Local dev: Use Docker Compose default: postgresql://postgres:postgres@localhost:5432/securestack?sslmode=disable
# - Production: Use Vercel Postgres or managed PostgreSQL (sslmode=require)
# - Type: String (URI)
# - Security: SECRET — Never commit actual value, use environment variables
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/securestack?sslmode=disable"

# [REQUIRED] JWT (JSON Web Token) signing secret
# - Used for: Signing/verifying session tokens and secure cookies
# - Length: Minimum 32 characters (256-bit), recommend 64 characters
# - Generate: `openssl rand -hex 32` (32 byte = 256 bits)
# - Type: Hex string
# - Security: SECRET — Critical security value, rotate periodically
# - Rotation: Invalidates all active sessions if changed
JWT_SECRET=690a9d5bd19153a28f0f8e8ede800f321eb2f96d743652bace7554dd29860769

# [REQUIRED] AES-256 encryption key for sensitive data
# - Used for: Encrypting personally identifiable information (PII) and secrets
# - Length: 64 hex characters (256-bit AES)
# - Generate: `openssl rand -hex 64`
# - Type: Hex string
# - Security: SECRET — Never commit, rotate only in coordination with password resets
# - Data affected: User emails, phone numbers, encrypted fields in database
ENCRYPTION_KEY=9f8b365a8b47db365e40d801fbde6bef9886b76f321eb9ff2ba234c0e6227995f564f369dfe71380ccfff523950a21c5bedeb5e346fe0b9d2c00097046e87657

# ══════════════════════════════════════════════════════════════════════════════
# TIER 2 — RECOMMENDED (Feature-gated; app runs without these but features degrade)
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# Email Service (Contact Forms, Newsletters)
# ──────────────────────────────────────────────────────────────────────────────

# [RECOMMENDED] Resend API Key
# - Used for: Sending transactional emails (contact form, newsletters, verification)
# - Provider: Resend (https://resend.com)
# - Get key: Resend Dashboard → API Keys → Create API Key
# - Type: String (API token)
# - Security: SECRET — Backend only
# - Fallback: If missing, contact form silently fails (see logs)
# - Cost: Free up to 100 emails/day, $20/month for more
RESEND_API_KEY=re_Nz3k7tXt_um6TZTmiAyAz5Zq9ng9PsrJN

# [RECOMMENDED] Email "From" address
# - Used for: Sender address in all outgoing emails
# - Format: noreply@yourdomain.com (verified with Resend)
# - Must be verified in Resend dashboard before sending
# - Type: Email address
# - Security: NEXT_PUBLIC (non-sensitive)
EMAIL_FROM=noreply@okeson.dev

# [RECOMMENDED] Email "Reply-To" address
# - Used for: Where recipients can reply to emails
# - Format: monitored@yourdomain.com or personal email
# - Type: Email address
# - Security: NEXT_PUBLIC (non-sensitive)
# - Best practice: Use monitored inbox for contact form replies
EMAIL_REPLY_TO=okeson453@gmail.com

# ──────────────────────────────────────────────────────────────────────────────
# Search Service (Full-Text Search, Autocomplete)
# ──────────────────────────────────────────────────────────────────────────────

# [RECOMMENDED] Algolia Application ID
# - Used for: Search indexing and querying across blog posts, projects
# - Provider: Algolia (https://algolia.com)
# - Get ID: Algolia Dashboard → Your App → App ID
# - Type: String (alphanumeric)
# - Security: NEXT_PUBLIC (read-only key needed for frontend)
# - Rate limit: Varies by plan, free tier: 50k operations/month
ALGOLIA_APP_ID=IWJ1IDJJNK

# [RECOMMENDED] Algolia Search Key (Public)
# - Used for: Frontend search queries (read-only)
# - Get key: Algolia Dashboard → API Keys → Search-Only API Key
# - Type: String (long alphanumeric)
# - Security: NEXT_PUBLIC (only allows search, not indexing)
# - Permissions: Read-only, cannot modify indexes
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=87be503ac645483a553619e24a66c34b

# [RECOMMENDED] Algolia Admin Key (Secret)
# - Used for: Backend indexing and configuration
# - Get key: Algolia Dashboard → API Keys → Admin API Key
# - Type: String (long alphanumeric)
# - Security: SECRET — Backend only, never expose to frontend
# - Permissions: Full access to manage indexes and settings
# - Usage: Called by API route /api/reindex-search on manual request
ALGOLIA_ADMIN_KEY=ee37e99ca695a5c3850521467c3a1a0c18e0c1a4fcb3910971dadbf9f90f5b67

# ══════════════════════════════════════════════════════════════════════════════
# TIER 3 — OPTIONAL (Monitoring, Analytics — not needed for local dev)
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# Error Tracking & Crash Reporting (Sentry)
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Sentry DSN (Data Source Name)
# - Used for: Capturing and reporting runtime errors and exceptions
# - Provider: Sentry (https://sentry.io)
# - Get DSN: Sentry Dashboard → Projects → [Your Project] → Client Keys (DSN)
# - Format: https://[key]@[host].ingest.sentry.io/[projectId]
# - Type: String (URL)
# - Security: NEXT_PUBLIC (ok to expose, contains project ID only)
# - Fallback: If missing, errors are logged to console only
# - Error capture: Includes stack traces, user session data, breadcrumbs
# - Sensitive data: Exclude user PII via beforeSend hook (see sentry.client.config.ts)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX

# [OPTIONAL] Sentry Auth Token
# - Used for: Authentication for Sentry CLI and backend integration
# - Get token: Sentry Settings → Auth Tokens → Create Token
# - Type: String (token)
# - Security: SECRET — Backend only
# - Usage: CI/CD pipelines for source maps and release tracking
# - Permissions: project:releases, org:read
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Sentry Organization slug
# - Used for: Identifying which Sentry organization to use
# - Get value: Sentry Dashboard → Settings → Organization → Slug
# - Type: String (slugified organization name)
# - Used with: Sentry Auth Token for CLI operations
SENTRY_ORG=your-org

# [OPTIONAL] Sentry Project slug
# - Used for: Identifying which Sentry project to report errors to
# - Get value: Sentry Dashboard → Projects → [Project] → Settings → Slug
# - Type: String (project identifier)
# - Must match: NEXT_PUBLIC_SENTRY_DSN project portion
SENTRY_PROJECT=your-project

# ──────────────────────────────────────────────────────────────────────────────
# Search Engine Verification (SEO)
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Google Search Console Verification Token
# - Used for: Proving domain ownership to Google Search Console
# - Get token: https://search.google.com/search-console → Add Property → Verify Ownership → HTML tag
# - Copy value: From <meta name="google-site-verification" content="[VALUE]">
# - Type: String (alphanumeric)
# - Security: NEXT_PUBLIC (ok to expose, used for verification only)
# - Where used: app/layout.tsx in metadata.verification.google
# - Verification: Automatically added to all pages via metadata
# - Purpose: Subdomain: okeson.dev
GOOGLE_SITE_VERIFICATION=kdktpccfI_ClUfkNfrztfW1xT_cE9D3m4snv_k1PY_Q

# ──────────────────────────────────────────────────────────────────────────────
# Rate Limiting & Abuse Prevention (Upstash Redis)
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Upstash Redis REST URL
# - Used for: Distributed rate limiting for API routes and middleware
# - Provider: Upstash (https://upstash.com) — Redis as a Service
# - Get URL: Upstash Dashboard → [Database] → REST API → UPSTASH_REDIS_REST_URL
# - Format: https://[name]-[region].upstash.io
# - Type: String (HTTPS URL)
# - Security: NEXT_PUBLIC (id only, no secrets), but typically SECRET by convention
# - Local fallback: Uses in-memory rate limiter if URL not set
# - Rate limits: Contact form (5/hour), API routes (100/minute per IP)
# - Alternative: Set to empty string to use mock Redis for testing
UPSTASH_REDIS_REST_URL=https://adapted-stallion-92277.upstash.io

# [OPTIONAL] Upstash Redis REST Token
# - Used for: Authentication with Upstash Redis
# - Get token: Upstash Dashboard → [Database] → REST API → UPSTASH_REDIS_REST_TOKEN
# - Type: String (bearer token)
# - Security: SECRET — Backend only
# - Usage: Combined with UPSTASH_REDIS_REST_URL for middleware rate limiting
# - Rotation: Change in Upstash dashboard, update in Vercel immediately
UPSTASH_REDIS_REST_TOKEN=ggAAAAAAAWh1AAIgcDFmWwGDz2qPEcyx6wcoU9IQz-tT8kp0CDnkNwWBeaWH-g

# ──────────────────────────────────────────────────────────────────────────────
# CAPTCHA & Bot Prevention (Cloudflare Turnstile)
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Cloudflare Turnstile Site Key
# - Used for: Rendering CAPTCHA widget on frontend forms
# - Provider: Cloudflare (https://dash.cloudflare.com) → Turnstile
# - Get key: Turnstile Dashboard → Create Site → Copy Site Key
# - Type: String (alphanumeric)
# - Security: NEXT_PUBLIC (safe, required by frontend)
# - Usage: Contact form, comment forms (if applicable)
# - Purpose: Prevent bot spam and automated abuse
# - Challenge types: Managed (Cloudflare decides), Non-interactive
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxx

# [OPTIONAL] Cloudflare Turnstile Secret Key
# - Used for: Verifying CAPTCHA responses on backend
# - Get key: Turnstile Dashboard → Create Site → Copy Secret Key
# - Type: String (alphanumeric)
# - Security: SECRET — Backend only, never expose to frontend
# - Usage: /api/contact form submission verification
# - Validation: POST to https://challenges.cloudflare.com/turnstile/validate
CLOUDFLARE_TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxx

# ──────────────────────────────────────────────────────────────────────────────
# Security & Monitoring Webhooks
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Security Event Webhook URL
# - Used for: Real-time notifications of security events (rate limit hits, failed auth, etc.)
# - Provider: Slack or Discord webhook
# - Get URL (Slack): https://api.slack.com/messaging/webhooks → Create New Webhook
# - Get URL (Discord): Discord Server → Channel Settings → Webhooks → Create Webhook
# - Type: String (HTTPS URL)
# - Security: SECRET — Webhook credentials embedded in URL
# - Events: Failed auth attempts, rate limit exceeded, suspicious activity
# - Format: POST JSON payload with event details and timestamp
# - Fallback: If missing, events only logged to console (check server logs with `npm run dev`)
SECURITY_WEBHOOK_URL=https://hooks.slack.com/services/XXX/XXX/XXX

# ──────────────────────────────────────────────────────────────────────────────
# Progressive Web App & Offline Support
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Enable Progressive Web App Features
# - Used for: Service workers, offline caching, install prompts
# - Values: "true" (enable), "false" (disable)
# - Type: String (boolean as string in env)
# - Default: "true"
# - Purpose: Allow users to install app, use offline, sync in background
# - Note: Requires manifest.json and service worker setup
NEXT_PUBLIC_PWA_ENABLED=true

# ──────────────────────────────────────────────────────────────────────────────
# Real-Time Updates & WebSocket
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Real-time Updates Base URL
# - Used for: WebSocket and real-time API endpoints
# - Format: https://yourdomain.com (not the app itself, typically separate service)
# - Type: String (URL)
# - Usage: For potential real-time features (notifications, live board, etc.)
# - Current: Not actively used in current version
NEXT_PUBLIC_REALTIME_URL=https://yourdomain.com

# [OPTIONAL] WebSocket Server URL
# - Used for: WebSocket connections for real-time features
# - Format: wss://yourdomain.com (secure WebSocket)
# - Type: String (WSS URL)
# - Security: NEXT_PUBLIC (connection details ok, auth via token)
# - Usage: Potential future feature for live updates
# - Fallback: Polling if WebSocket unavailable
NEXT_PUBLIC_WS_URL=wss://yourdomain.com

# ══════════════════════════════════════════════════════════════════════════════
# TIER 4 — CI/CD & DEVELOPMENT ONLY (GitHub Actions Secrets, not .env.local)
# ══════════════════════════════════════════════════════════════════════════════

# Note: These variables are only needed in CI/CD pipelines (GitHub Actions).
# Set them in: GitHub Repository → Settings → Secrets and variables → Actions
# Do NOT add to .env.local for local development

# [CI/CD] Vercel Deployment Token
# - Used for: Deploying to Vercel via CLI (vercel deploy)
# - Get token: https://vercel.com/account/tokens → Create Token
# - Type: String (token)
# - Security: SECRET — CI/CD only
# - Scope: Full access to projects
# VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [CI/CD] Vercel Organization ID
# - Used for: Identifying Vercel Team/Organization
# - Get ID: Vercel Dashboard → Team Settings → Team ID
# - Type: String (UUID)
# - Used with: VERCEL_TOKEN for deployment
# VERCEL_ORG_ID=team_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [CI/CD] Vercel Project ID
# - Used for: Identifying specific Vercel project
# - Get ID: Vercel Dashboard → [Project] → Settings → Project ID
# - Type: String (UUID)
# - Used with: VERCEL_TOKEN and VERCEL_ORG_ID
# VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [CI/CD] Security Scanning Token (Snyk)
# - Used for: Automated dependency vulnerability scanning
# - Provider: Snyk (https://snyk.io)
# - Get token: Snyk Dashboard → Account Settings → Auth Tokens
# - Type: String (token)
# - Security: SECRET — CI/CD only
# - Usage: Snyk CLI scans dependencies before deployment
# SNYK_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────────────────────
# Feature Flags & Admin Configuration
# ──────────────────────────────────────────────────────────────────────────────

# [DEVELOPMENT] Enable Feature Flags
# - Used for: Runtime feature toggles (enable/disable features without deploy)
# - Values: "true" (enabled), "false" (disabled)
# - Type: String (boolean)
# - Currently disabled: Can enable for A/B testing, beta features
# - Provider: Optional feature flag service (not currently integrated)
NEXT_PUBLIC_FEATURE_FLAGS_ENABLED=true

# [BACKEND] Admin API Token Secret
# - Used for: Securing internal admin API endpoints
# - Length: 64+ random characters
# - Generate: `openssl rand -hex 32`
# - Type: Hex string
# - Security: SECRET — Backend only
# - Usage: Verify X-Admin-Token header on admin routes
# - Routes: /api/admin/*, potentially cache purge, rebuild endpoints
ADMIN_API_TOKEN_SECRET=d5805d547b2692d0d1d8893689da06b1ccf426126cd7ad5c555df6a320a39770972b

# ──────────────────────────────────────────────────────────────────────────────
# Analytics & Product Intelligence (PostHog)
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] PostHog API Key
# - Used for: Product analytics, event tracking, feature flags
# - Provider: PostHog (https://posthog.com)
# - Get key: PostHog Dashboard → Project → Settings → API Key
# - Type: String (alphanumeric)
# - Security: NEXT_PUBLIC (safe, identifies project only)
# - Usage: Tracks user events, feature usage, performance metrics
# - Fallback: If missing, analytics tracking disabled
# - GDPR: Events sent to eu.posthog.com (EU) or us.posthog.com (US)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] PostHog API Host
# - Used for: Analytics endpoint URL
# - Values: https://us.posthog.com (default), https://eu.posthog.com (GDPR)
# - Type: String (URL)
# - Choose based on: User location and GDPR requirements
# - Must match: PostHog project region configuration
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# ──────────────────────────────────────────────────────────────────────────────
# Email Service Alternative (SendGrid)
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] SendGrid API Key
# - Used for: Alternative email service (transactional emails, newsletters)
# - Provider: SendGrid (https://sendgrid.com)
# - Get key: SendGrid Dashboard → Settings → API Keys → Create API Key
# - Type: String (token)
# - Security: SECRET — Backend only
# - Usage: Alternative to Resend, not currently implemented
# - Rate limit: Varies by plan
# - Note: Requires integration code if used alongside Resend
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────────────────────
# Payment Processing (Stripe) — if implementing payments
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Stripe Publishable Key
# - Used for: Client-side Stripe elements and payment forms
# - Provider: Stripe (https://stripe.com)
# - Get key: Stripe Dashboard → Developers → API Keys → Publishable Key
# - Format: pk_live_xxx (production), pk_test_xxx (testing)
# - Type: String (key)
# - Security: NEXT_PUBLIC (ok to expose, limited to payment flow)
# - Usage: Stripe.js library for forms, redirects
# - Test mode: Use pk_test_xxx for local development
# - Note: Not currently implemented, for future payment features
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# [OPTIONAL] Stripe Secret Key
# - Used for: Server-side charge creation, webhook verification, refunds
# - Get key: Stripe Dashboard → Developers → API Keys → Secret Key
# - Format: sk_live_xxx (production), sk_test_xxx (testing)
# - Type: String (key)
# - Security: SECRET — Backend only, never expose to frontend
# - Usage: Process payments, manage subscriptions, refunds
# - Rotation: Deprecated old keys, use latest for API calls
# - Test mode: Use sk_test_xxx for local development
STRIPE_SECRET_KEY=sk_live_xxx

# ──────────────────────────────────────────────────────────────────────────────
# File Storage & CDN (AWS S3 / Cloudflare R2)
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] AWS Region
# - Used for: S3 bucket region for file uploads
# - Common values: us-east-1, us-west-2, eu-west-1, ap-southeast-1
# - Type: String (AWS region code)
# - Security: NEXT_PUBLIC (ok to expose, identifies CDN region)
# - Usage: Configure AWS SDK for uploads, CDN performance
NEXT_PUBLIC_AWS_REGION=us-east-1

# [OPTIONAL] AWS Access Key ID
# - Used for: Authentication with AWS S3 for file uploads
# - Get key: AWS IAM Console → Users → [User] → Security Credentials → Access Keys
# - Format: AKIA... (20 characters)
# - Type: String (key ID)
# - Security: SECRET — Backend only for API calls
# - Usage: S3 bucket file uploads, asset management
# - Rotation: Regenerate periodically, delete old keys
# - Permissions: Limited to s3:PutObject, s3:GetObject (principle of least privilege)
AWS_ACCESS_KEY_ID=your_access_key

# [OPTIONAL] AWS Secret Access Key
# - Used for: Authentication secret for AWS S3
# - Get key: AWS IAM Console → Users → [User] → Security Credentials → Access Keys (show/copy)
# - Format: Long random string (40+ characters)
# - Type: String (secret)
# - Security: SECRET — Backend only, never expose to frontend
# - Usage: Combined with Access Key for API authentication
# - Rotation: Delete when no longer needed
AWS_SECRET_ACCESS_KEY=your_secret_key

# [OPTIONAL] AWS S3 Bucket Name
# - Used for: Destination bucket for file uploads
# - Format: your-bucket-name (lowercase, hyphens only)
# - Type: String (bucket name)
# - Security: NEXT_PUBLIC (bucket name is not sensitive)
# - Usage: Configure upload destination
# - Must exist and bucket policy allows PutObject from app
# - Alternative: Use Cloudflare R2 with compatible API
AWS_S3_BUCKET=your-bucket-name

# ──────────────────────────────────────────────────────────────────────────────
# CMS & Headless Content Integration (optional)
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] CMS API URL
# - Used for: Connecting to headless CMS for content management
# - Provider: Contentful, Strapi, Sanity, or other CMS
# - Format: https://your-cms.com/api or https://api.your-cms.com
# - Type: String (URL)
# - Security: NEXT_PUBLIC (endpoint URL, auth via token)
# - Usage: Fetch blog posts, project descriptions, portfolio content
# - Currently: Using Prisma database directly, not active
NEXT_PUBLIC_CMS_API_URL=https://your-cms.com/api

# [OPTIONAL] CMS API Token
# - Used for: Authenticating with CMS API
# - Get token: CMS Dashboard → API Tokens → Generate Token (read-only)
# - Type: String (token/key)
# - Security: SECRET — Backend only, never expose to frontend
# - Usage: Authorization header for CMS API requests
# - Scopes: Typically read-only for published content
# - Rotation: Regenerate in CMS dashboard, update here
CMS_API_TOKEN=your-cms-token

