# ─────────────────────────────────────────────────────────────────────────────
# SECURESTACK PORTFOLIO — ENVIRONMENT CONFIGURATION
# Copy to .env.local: `cp .env.example .env.local`
# Run interactive setup: `npm run setup:env`
# ─────────────────────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════════════════════
# TIER 1 — REQUIRED (App will not start without these)
# ══════════════════════════════════════════════════════════════════════════════

# The public URL of this app (used for OG images, redirects, sitemaps)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL connection string
# Quick start: use the docker-compose default below
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/securestack?sslmode=disable"

# JWT signing secret — generate with: openssl rand -hex 32
# NEVER commit the real value
JWT_SECRET=change_me_generate_with_openssl

# AES-256 encryption key — generate with: openssl rand -hex 64
ENCRYPTION_KEY=change_me_generate_with_openssl

# ══════════════════════════════════════════════════════════════════════════════
# TIER 2 — RECOMMENDED (Feature-gated; app runs without these but features degrade)
# ══════════════════════════════════════════════════════════════════════════════

# Email (contact form, digest emails)
# Get key at: https://resend.com → API Keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_REPLY_TO=contact@yourdomain.com

# Search (full-text search, autocomplete)
# Get keys at: https://algolia.com → Your App → API Keys
# ALGOLIA_APP_ID=XXXXXXXXXX
# NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ALGOLIA_ADMIN_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI features (blog assist, content generation)
# Get key at: https://platform.openai.com → API Keys
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ══════════════════════════════════════════════════════════════════════════════
# TIER 3 — OPTIONAL (Monitoring, analytics — not needed for local dev)
# ══════════════════════════════════════════════════════════════════════════════

# Error tracking (Sentry)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX

# ──────────────────────────────────────────────────────────────────────────────
# Google Search Console — SEO Verification & Monitoring
# ──────────────────────────────────────────────────────────────────────────────
# Get your verification token:
# 1. Go to: https://search.google.com/search-console
# 2. Add property: "okeson.dev" (or your domain)
# 3. Click "Verify Ownership" → Choose "HTML tag" method
# 4. Copy the value from content="XXXXX" and paste below
# Used by: app/layout.tsx metadata.verification.google
# GOOGLE_SITE_VERIFICATION=your_verification_token_here
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project

# Upstash Redis (rate limiting in production — mock used locally)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Turnstile (CAPTCHA)
# NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxx
# CLOUDFLARE_TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxx

# Security event webhook (Slack or Discord)
# SECURITY_WEBHOOK_URL=https://hooks.slack.com/services/XXX/XXX/XXX

# PWA & Offline Support
# NEXT_PUBLIC_PWA_ENABLED=true

# WebSocket / Real-time Updates
# NEXT_PUBLIC_REALTIME_URL=https://yourdomain.com
# NEXT_PUBLIC_WS_URL=wss://yourdomain.com

# ══════════════════════════════════════════════════════════════════════════════
# TIER 4 — CI/CD ONLY (Set in GitHub Actions Secrets, not .env.local)
# ══════════════════════════════════════════════════════════════════════════════

# VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VERCEL_ORG_ID=team_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SNYK_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Feature Flags
NEXT_PUBLIC_FEATURE_FLAGS_ENABLED=true
ADMIN_API_TOKEN_SECRET=your-admin-token-secret

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# SendGrid (alternative email)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Stripe (if implementing payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx

# File Upload (S3/Cloudflare R2)
NEXT_PUBLIC_AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=your-bucket-name

# CMS / Headless Integration (optional)
NEXT_PUBLIC_CMS_API_URL=https://your-cms.com/api
CMS_API_TOKEN=your-cms-token
