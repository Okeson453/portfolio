{
    "name": "secure-stack-portfolio",
    "version": "1.0.0",
    "private": true,
    "description": "Modern cybersecurity portfolio with interactive UI and security visualization",
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=10.0.0"
    },
    "scripts": {
        "dev": "next dev --turbopack",
        "dev:safe": "concurrently --names 'next,tsc' --prefix-colors 'cyan,yellow' \"next dev --turbopack\" \"tsc --noEmit --watch --preserveWatchOutput\"",
        "dev:debug": "NODE_OPTIONS='--inspect' next dev --turbopack",
        "build": "npm run env:validate && next build",
        "start": "next start",
        "lint": "eslint . --ext .ts,.tsx --cache --max-warnings=0",
        "lint:fix": "eslint . --ext .ts,.tsx --fix --cache",
        "lint:staged": "eslint --fix --cache",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "type-check": "tsc --noEmit",
        "type-check:watch": "tsc --noEmit --watch --preserveWatchOutput --incremental",
        "test": "jest",
        "test:fast": "jest --testPathPattern='tests/' --no-coverage",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:ci": "jest --ci --coverage --forceExit",
        "e2e": "playwright test",
        "e2e:headed": "playwright test --headed",
        "e2e:debug": "playwright test --debug",
        "e2e:ui": "playwright test --ui",
        "lighthouse": "lhci autorun",
        "lighthouse:collect": "lhci collect",
        "lighthouse:assert": "lhci assert",
        "lighthouse:upload": "lhci upload",
        "security-check": "npm audit && npx snyk test",
        "generate-sitemap": "next-sitemap",
        "generate:og-image": "node scripts/generate-og-image.js",
        "analyze": "ANALYZE=true next build",
        "perf:audit": "bash scripts/performance-audit.sh 2>/dev/null || pwsh scripts/performance-audit.ps1",
        "perf:check": "npm run build && npm run start",
        "perf:lighthouse": "npm run start & sleep 5 && open http://localhost:3000",
        "db:up": "bash scripts/db-up.sh",
        "db:reset": "npx prisma migrate reset --force && npx prisma db seed 2>/dev/null || true",
        "db:studio": "npx prisma studio",
        "db:migrate": "npx prisma migrate dev",
        "db:push": "npx prisma db push",
        "db:seed": "npx prisma db seed",
        "setup:env": "bash scripts/setup-env.sh",
        "env:validate": "node scripts/validate-env.js",
        "verify:local": "bash scripts/verify-local.sh",
        "prepare": "husky",
        "audit:full": "npm run type-check && npm run lint && npm run test:ci && npm run build"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@prisma/client": "^5.22.0",
        "@radix-ui/react-avatar": "^1.1.2",
        "@radix-ui/react-dialog": "^1.1.4",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-radio-group": "^1.3.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.2",
        "@radix-ui/react-toast": "^1.2.4",
        "@tailwindcss/typography": "^0.5.19",
        "@upstash/ratelimit": "^2.0.5",
        "@upstash/redis": "^1.34.3",
        "@vercel/analytics": "^1.6.1",
        "bcryptjs": "^3.0.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "jose": "^6.1.3",
        "lucide-react": "^0.475.0",
        "next": "^15.1.7",
        "next-seo": "^7.1.0",
        "next-themes": "^0.4.4",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-hook-form": "^7.71.1",
        "react-hot-toast": "^2.5.0",
        "recharts": "^2.15.0",
        "resend": "^4.0.1",
        "tailwind-merge": "^2.6.1",
        "tailwindcss-animate": "^1.0.7",
        "zod": "^3.25.8",
        "@tanstack/react-query": "^5.51.0",
        "cmdk": "^1.0.0",
        "react-dropzone": "^14.2.3",
        "@sentry/nextjs": "^8.0.0",
        "posthog-js": "^1.115.0",
        "dompurify": "^3.1.0",
        "sonner": "^1.4.41",
        "@types/dompurify": "^3.0.5"
    },
    "devDependencies": {
        "@next/bundle-analyzer": "^15.1.7",
        "@playwright/test": "^1.49.1",
        "@tailwindcss/aspect-ratio": "^0.4.2",
        "@tailwindcss/forms": "^0.5.11",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.1.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^22.10.6",
        "@types/react": "^19.0.7",
        "@types/react-dom": "^19.0.3",
        "@typescript-eslint/eslint-plugin": "^8.26.0",
        "@typescript-eslint/parser": "^8.26.0",
        "autoprefixer": "^10.4.20",
        "concurrently": "^9.1.2",
        "eslint": "^9.17.0",
        "eslint-config-next": "^15.1.7",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "glob": "^10.4.5",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "lint-staged": "^15.2.12",
        "next-sitemap": "^4.2.3",
        "postcss": "^8.5.3",
        "prettier": "^3.4.2",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "prisma": "^5.22.0",
        "sharp": "^0.33.1",
        "tailwindcss": "^3.4.17",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.3",
        "lighthouse": "^11.0.0"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix --cache --max-warnings=0",
            "prettier --write"
        ],
        "*.{js,mjs,cjs}": [
            "eslint --fix --cache --max-warnings=0",
            "prettier --write"
        ],
        "*.{json,md,mdx,yaml,yml}": [
            "prettier --write"
        ],
        "*.{css,scss}": [
            "prettier --write"
        ],
        "prisma/schema.prisma": [
            "npx prisma format"
        ]
    },
    "keywords": [
        "cybersecurity",
        "portfolio",
        "nextjs",
        "security",
        "developer",
        "pentesting"
    ],
    "author": "Security Developer",
    "license": "MIT",
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    }
}