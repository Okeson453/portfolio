generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─── Auth ────────────────────────────────────────────────
model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String?
  name             String?
  avatarUrl        String?
  emailVerified    DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  recoveryCodes    String[]
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sessions           Session[]
  devices            Device[]
  passwordResets     PasswordReset[]
  verificationTokens VerificationToken[]
  roles              UserRole[]
  comments           Comment[]
  commentVotes       CommentVote[]

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Device {
  id         String   @id @default(cuid())
  userId     String
  userAgent  String
  ip         String
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── RBAC ────────────────────────────────────────────────
model Role {
  id          String           @id @default(cuid())
  name        String           @unique // admin | moderator | author | viewer
  description String?
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id    String           @id @default(cuid())
  name  String           @unique // e.g. "blog:publish", "users:write"
  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// ─── Content ─────────────────────────────────────────────
model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  tags        String[]
  status      String    @default("draft") // draft | review | published
  authorId    String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    Comment[]

  @@index([slug])
  @@index([status])
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  tech        String[]
  liveUrl     String?
  repoUrl     String?
  coverImage  String?
  status      String   @default("draft") // draft | published
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  title     String
  company   String?
  content   String
  avatarUrl String?
  rating    Int      @default(5)
  status    String   @default("pending") // pending | approved | rejected
  createdAt DateTime @default(now())
}

// ─── Comments ────────────────────────────────────────────
model Comment {
  id        String        @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  content   String
  status    String        @default("pending") // pending | approved | spam
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  post      BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id])
  parent    Comment?      @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[]     @relation("Replies")
  votes     CommentVote[]

  @@index([postId])
  @@index([authorId])
}

model CommentVote {
  userId    String
  commentId String
  value     Int // 1 or -1
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
}

// ─── Admin / Audit ───────────────────────────────────────
model AdminActionLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  details   Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  type      String // login_failed | rate_limit | waf_block | account_lockout
  userId    String?
  ip        String?
  userAgent String?
  details   Json?
  severity  String   @default("low") // low | medium | high | critical
  createdAt DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([createdAt])
}

model PerformanceMetric {
  id        String   @id @default(cuid())
  route     String
  lcp       Float?
  fid       Float?
  cls       Float?
  ttfb      Float?
  createdAt DateTime @default(now())
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Contact ─────────────────────────────────────────────
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  ip        String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ─── Blog Automation ──────────────────────────────────────
model EmailSubscriber {
  id                         String         @id @default(cuid())
  email                      String         @unique
  name                       String?
  status                     String         @default("active") // active | unsubscribed | bounced
  verifiedAt                 DateTime?
  verificationToken          String?
  verificationTokenExpiresAt DateTime?
  preferences                String[]       @default([]) // tags/categories they're interested in
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  sentEmails                 EmailHistory[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model BlogSchedule {
  id            String    @id @default(cuid())
  postId        String
  scheduledFor  DateTime
  frequency     String    @default("once") // once | weekly | biweekly | monthly
  enabled       Boolean   @default(true)
  publishedAt   DateTime?
  failureReason String?
  retryCount    Int       @default(0)
  maxRetries    Int       @default(3)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([scheduledFor])
  @@index([enabled])
  @@index([createdAt])
}

model SocialMediaShare {
  id        String    @id @default(cuid())
  postId    String
  platform  String // twitter | facebook | linkedin | threads
  postUrl   String
  content   String?
  scheduled DateTime?
  sentAt    DateTime?
  views     Int       @default(0)
  clicks    Int       @default(0)
  shares    Int       @default(0)
  status    String    @default("pending") // pending | scheduled | sent | failed
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([platform])
  @@index([status])
  @@index([createdAt])
}

model EmailHistory {
  id           String          @id @default(cuid())
  subscriberId String
  postId       String
  subject      String
  sentAt       DateTime        @default(now())
  openedAt     DateTime?
  clickedAt    DateTime?
  status       String          @default("sent") // sent | opened | clicked | bounced | failed
  metadata     Json?
  subscriber   EmailSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId])
  @@index([postId])
  @@index([sentAt])
}
